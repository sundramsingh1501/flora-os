# ============================================================
# Flora OS — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-minimum-32-chars
APP_BASE_URL=http://localhost:8501

# --- Database ---
DATABASE_URL=sqlite:///./flora_os.db
# Production: postgresql://user:password@host:5432/flora_os

# --- Encryption (for storing OAuth tokens) ---
ENCRYPTION_KEY=change-me-to-fernet-compatible-32-byte-base64-key

# --- Google OAuth (for Login + Gmail) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8501/auth/google/callback

# --- GitHub OAuth (for Login) ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8501/auth/github/callback

# --- Google Gemini AI ---
GEMINI_API_KEY=your-gemini-api-key

# --- News API ---
NEWS_API_KEY=your-newsapi-key

# --- Weather ---
OPENWEATHER_API_KEY=your-openweathermap-key

# --- Jobs ---
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# --- Market ---
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# --- Session ---
SESSION_COOKIE_MAX_AGE=2592000
# 2592000 seconds = 30 days
